@namespace Hattrick.Components.Shared.Lineup
@using Hattrick.Core.Models

<div class="bench-panel">
    @foreach (var slot in BenchPlayers)
    {
        <div class="bench-player" @key="slot.PlayerId" @onclick="() => HandlePlayerClick(slot)">
            <PlayerAvatar PlayerId="@slot.PlayerId" Position="@slot.Position" Size="PlayerAvatarSize.Small" />
        </div>
    }
</div>

@code {
    private IReadOnlyList<MatchLineupSlot> _previousBenchPlayers = Array.Empty<MatchLineupSlot>();

    [Parameter]
    public IReadOnlyList<MatchLineupSlot> BenchPlayers { get; set; } = Array.Empty<MatchLineupSlot>();

    [Parameter]
    public EventCallback<MatchLineupSlot> OnPlayerClick { get; set; }

    protected override bool ShouldRender()
    {
        // Check if parameters changed before updating the reference
        bool shouldRender = !ReferenceEquals(BenchPlayers, _previousBenchPlayers);

        // Update reference AFTER the check, so next ShouldRender can detect future changes
        _previousBenchPlayers = BenchPlayers;

        return shouldRender;
    }

    private async Task HandlePlayerClick(MatchLineupSlot slot)
    {
        await OnPlayerClick.InvokeAsync(slot);
    }
}

@namespace Hattrick.Components.Shared.Lineup
@using Hattrick.Core.Models
@using Hattrick.Core.Services

@inject ILineupPageService LineupPageService

<div class="lineup-page">
    <TabNavigation CurrentTab="currentTab" OnTabChanged="HandleTabChanged" />
    <FormationPitch Formation="lineup.Formation" Slots="starters" />
    <BenchPanel BenchPlayers="benchPlayers" />
</div>

@code {
    private const int DefaultTab = 1; // Lineup tab

    private int currentTab = DefaultTab;
    private TeamLineup lineup = new();
    private IReadOnlyList<MatchLineupSlot> starters = Array.Empty<MatchLineupSlot>();
    private IReadOnlyList<MatchLineupSlot> benchPlayers = Array.Empty<MatchLineupSlot>();
    private Guid _previousTeamId;

    [Parameter]
    public Guid TeamId { get; set; }

    protected override void OnParametersSet()
    {
        if (TeamId != _previousTeamId)
        {
            _previousTeamId = TeamId;
            LoadLineupData();
        }
    }

    private void LoadLineupData()
    {
        lineup = LineupPageService.GetLineupForTeam(TeamId);
        starters = LineupPageService.GetStarters(TeamId);
        benchPlayers = LineupPageService.GetBenchPlayers(TeamId);
    }

    private void HandleTabChanged(int tabIndex)
    {
        currentTab = tabIndex;
    }
}

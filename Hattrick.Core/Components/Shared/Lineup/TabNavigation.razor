@namespace Hattrick.Components.Shared.Lineup

<div class="tab-navigation bg-green">
    @for (int i = 0; i < TabLabels.Length; i++)
    {
        var tabIndex = i;
        <div class="tab-item @(CurrentTab == tabIndex ? "active" : "")" @onclick="() => OnTabClicked(tabIndex)">
            @TabLabels[tabIndex]
        </div>
    }
</div>

@code {
    private static readonly string[] TabLabels = ["Load", "Lineup", "Team Orders", "Penalty Takers", "Review", "Send Orders"];

    [Parameter]
    public int CurrentTab { get; set; }

    [Parameter]
    public EventCallback<int> OnTabChanged { get; set; }

    private async Task OnTabClicked(int tabIndex)
    {
        await OnTabChanged.InvokeAsync(tabIndex);
    }
}

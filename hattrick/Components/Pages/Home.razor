@page "/"
@using Hattrick.Components.Shared.Home

<div class="home-dashboard">
    <div class="dashboard-top-row">
        <ClubInfoCard ClubName="FC Nordheim" Division="Division I" Fans="8 500" />
        <UpcomingMatchesPanel Matches="@_upcomingMatches" />
    </div>

    <ActivityFeed Items="@_activityItems" />

    <QuickLinksSection Links="@_quickLinks" />
</div>

@code {
    private readonly IReadOnlyList<UpcomingMatchesPanel.MatchInfo> _upcomingMatches = new[]
    {
        new UpcomingMatchesPanel.MatchInfo("Week 3", "FC Rotwald"),
        new UpcomingMatchesPanel.MatchInfo("Week 4", "SC Bergtal"),
        new UpcomingMatchesPanel.MatchInfo("Week 5", "SV Flussheim")
    };

    private readonly IReadOnlyList<ActivityFeed.FeedItem> _activityItems = new[]
    {
        new ActivityFeed.FeedItem("match", "Won 3-1 against FC Rotwald"),
        new ActivityFeed.FeedItem("training", "Training completed: Passing"),
        new ActivityFeed.FeedItem("transfer", "Player listed on transfer market")
    };

    private readonly IReadOnlyList<QuickLinksSection.QuickLink> _quickLinks = new[]
    {
        new QuickLinksSection.QuickLink("Set Lineup", "/lineup"),
        new QuickLinksSection.QuickLink("View Squad", "/players"),
        new QuickLinksSection.QuickLink("Check Finances", "/finance"),
        new QuickLinksSection.QuickLink("Transfer Market", "/transfers")
    };
}

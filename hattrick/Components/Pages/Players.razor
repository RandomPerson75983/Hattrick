@page "/players"
@using Hattrick.Core.Models
@using Hattrick.Core.Services
@using System.Globalization
@inject IPlayerService PlayerService
@inject IPlayerDisplayService DisplayService
@inject IPlayerStatsService StatsService

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="error-message">@_errorMessage</div>
}

<div class="players-page">
    <h1 class="players-title">Your @_players.Count players</h1>

    <div class="players-layout">
        <div class="players-main-content">
            <div class="skill-table">
                <div class="skill-table-header">
                    <span class="col-player">player</span>
                    <span class="col-age">age</span>
                    <span class="col-tsi">tsi</span>
                    <span class="col-wage">wage</span>
                    <span class="col-specialty">specialty</span>
                    <span class="col-form">form</span>
                    @foreach (var skillType in _displayedSkillTypes)
                    {
                        <span class="col-skill">@GetSkillAbbreviation(skillType)</span>
                    }
                    <span class="col-position">position</span>
                </div>

                @foreach (var player in _players)
                {
                    <div class="player-row" @key="player.Id">
                        <div class="player-name-cell">
                            <a class="player-name" href="/players/@player.Id">@player.Name</a>
                        </div>
                        <div class="age-cell">@DisplayService.FormatAge(player.Age, player.AgeDays)</div>
                        <div class="tsi-cell">@player.TSI.ToString("N0", CultureInfo.InvariantCulture)</div>
                        <div class="wage-cell">@player.Wage.ToString("N0", CultureInfo.InvariantCulture)</div>
                        <div class="specialty-cell">@DisplayService.GetSpecialtyDisplay(player.Specialty)</div>
                        <div class="form-cell">@player.Form</div>

                        @foreach (var skillType in _displayedSkillTypes)
                        {
                            var skillValue = player.Skills.TryGetValue(skillType, out var sv) ? sv : 0.0;
                            <div class="skill-cell" @key="skillType">
                                <div class="skill-bar @DisplayService.GetSkillColorClass(skillValue)"
                                     style="width: @DisplayService.GetSkillBarPercent(skillValue)%"></div>
                            </div>
                        }

                        <div class="best-position-cell">@DisplayService.GetPositionDisplay(player.BestPosition)</div>
                    </div>
                }
            </div>
        </div>

        <div class="players-sidebar">
            <div class="team-stats-sidebar">
                <div class="team-total-section">
                    <h3>Team Total</h3>
                    <div class="stats-row"><span class="stats-label">TSI</span><span class="stats-value">@_totals.TotalTSI.ToString("N0", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Wage</span><span class="stats-value">@_totals.TotalWage.ToString("N0", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Estimated Value</span><span class="stats-value">@_totals.TotalEstimatedValue.ToString("N0", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Nationalities</span><span class="stats-value">@_totals.NationalityCount</span></div>
                    <div class="stats-row"><span class="stats-label">Injured</span><span class="stats-value">@_totals.InjuredCount</span></div>
                    <div class="stats-row"><span class="stats-label">Red cards</span><span class="stats-value">@_totals.RedCardCount</span></div>
                    <div class="stats-row"><span class="stats-label">Yellow Cards</span><span class="stats-value">@_totals.YellowCardCount</span></div>
                </div>
                <div class="team-average-section">
                    <h3>Team Average</h3>
                    <div class="stats-row"><span class="stats-label">TSI</span><span class="stats-value">@_averages.AvgTSI.ToString("N0", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Wage</span><span class="stats-value">@_averages.AvgWage.ToString("N0", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Estimated Value</span><span class="stats-value">@_averages.AvgEstimatedValue.ToString("N0", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Age</span><span class="stats-value">@_averages.AvgAge.ToString("N1", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Form</span><span class="stats-value">@_averages.AvgForm.ToString("N1", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Stamina</span><span class="stats-value">@_averages.AvgStamina.ToString("N1", CultureInfo.InvariantCulture)</span></div>
                    <div class="stats-row"><span class="stats-label">Exp</span><span class="stats-value">@_averages.AvgExperience.ToString("N1", CultureInfo.InvariantCulture)</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<Player> _players = [];
    private IReadOnlyList<SkillType> _displayedSkillTypes = Array.Empty<SkillType>();
    private TeamTotals _totals = new();
    private TeamAverages _averages = new();
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _displayedSkillTypes = DisplayService.GetDisplayedSkillTypes();
            _players = PlayerService.GetAllPlayers();
            _totals = StatsService.GetTeamTotals(_players);
            _averages = StatsService.GetTeamAverages(_players);
            await Task.CompletedTask;
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load player data.";
        }
    }

    private static string GetSkillAbbreviation(SkillType skillType) => skillType switch
    {
        SkillType.Keeper => "Kp",
        SkillType.Defending => "Def",
        SkillType.Playmaking => "Pm",
        SkillType.Winger => "Wi",
        SkillType.Scoring => "Sc",
        SkillType.Passing => "Ps",
        SkillType.SetPieces => "Sp",
        _ => skillType.ToString()
    };
}

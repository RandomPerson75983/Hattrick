@namespace Hattrick.Components.Shared.Home

<div class="activity-feed">
    <h3 class="panel-title">Activity</h3>
    <div class="feed-list">
        @foreach (var item in Items)
        {
            <div class="feed-item feed-@item.Type">
                <span class="feed-message">@item.Message</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public IReadOnlyList<FeedItem> Items { get; set; } = Array.Empty<FeedItem>();

    public record FeedItem(string Type, string Message);
}
